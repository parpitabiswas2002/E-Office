{
  "name": "e-office-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "server"
  ],
  "scripts": {
    "dev:user": "npm run dev --workspace=apps/user-frontend",
    "dev:admin": "npm run dev --workspace=apps/admin-frontend",
    "dev:server": "node server/src/local-server.js",
    "build:user": "npm run build --workspace=apps/user-frontend",
    "build:admin": "npm run build --workspace=apps/admin-frontend",
    "deploy:server": "npm run deploy --workspace=server",
    "build": "echo 'No root build required'"
  }
}
