{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "my-office-letter-app",
  "main": "src/backend/index.js",
  "compatibility_date": "2026-05-25",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "vars": {
    "GEMINI_API_KEY": "your_gemini_api_key_here"
  }
}
